<!DOCTYPE html>
<html lang="en">
 
<head>
<meta charset="UTF-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HTML Form</title>
</head>
 
<body>
<form action="/register" method="post">
<label for="name">Full Name:</label>
<input type="text" name="name" id="name" required><br><br>
 
        <label for="email">Email Address:</label>
<input type="email" name="email" id="email" required><br><br>
 
        <label for="password">Password:</label>
<input type="password" name="password" id="password" required><br><br>
 
        <label for="cPassword">Confirm Password:</label>
<input type="password" name="cPassword" id="cPassword" required><br><br>
 
        <label for="phone">Mobile Number: </label>
<input type="tel" name="phone" id="phone" placeholder="123-456-567" pattern="[0-9]{3}-[0-9]{3}-[0-9]{3}"
            required><br><br>
 
        <label for="dob">Date of Birth: </label>
<input type="date" name="dob" id="dob" required><br><br>
 
        <div>
<label for="gender">Gender:</label> <br><br>
<input type="radio" id="male" name="gender" value="male">
<label for="male">Male</label>
 
            <input type="radio" id="female" name="gender" value="female">
<label for="female">Female</label>
 
            <input type="radio" id="other" name="gender" value="other">
<label for="other">Other</label>
</div>
 
        <div>
<label for="Course">Course Selection:</label>
<select name="Course" id="Course">
<option value="Science">Science</option>
<option value="Math">Math</option>
<option value="Computer">Computer</option>
</select>
</div>
 
        <div>
<label for="hobbies">Hobbies:</label>
<label>
                Cricket
<input type="checkbox" name="hobbies" value="Cricket">
</label>
<label>
                Art
<input type="checkbox" name="hobbies" value="Art">
</label>
<label>
                Music
<input type="checkbox" name="hobbies" value="music">
</label>
</div>
<div>
<label for="address">Address:</label>
<textarea id="address" name="address" placeholder="Enter Address" rows="5" cols="32"></textarea>
</div><br><br>
 
        <input type="submit" value="submit">
 
    </form>
</body>
</html>
